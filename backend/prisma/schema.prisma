generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FACULTY
  STUDENT
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  rfid      String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  student StudentProfile?
  faculty FacultyProfile?
  admin   AdminProfile?

  attendanceRecords AttendanceRecord[]
}

model StudentProfile {
  userId     Int    @id
  regNumber  String @unique
  department String

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes           Class[]
}

model FacultyProfile {
  userId     Int    @id
  employeeId String @unique
  department String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes Class[]
}

model AdminProfile {
  userId Int @id

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Slot {
  id        Int       @id @default(autoincrement())
  slotName  String    @unique
  dayOfWeek DayOfWeek
  startTime DateTime
  endTime   DateTime

  createdAt DateTime @default(now())
  courses   Course[]

  @@index([dayOfWeek, startTime, endTime])
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model Venue {
  id          Int          @id @default(autoincrement())
  room        String
  block       String
  createdAt   DateTime     @default(now())
  rfidReaders RFIDReader[]
  classes     Class[]

  @@unique([room, block])
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
}

model RFIDReader {
  id               Int          @id @default(autoincrement())
  roomId           Int
  deviceIdentifier String       @unique
  status           DeviceStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())

  venue Venue @relation(fields: [roomId], references: [id], onDelete: Cascade)

  attendanceRecords AttendanceRecord[]

  @@index([roomId])
}

model Course {
  id         Int      @id @default(autoincrement())
  courseName String   @map("course_name")
  courseCode String   @unique @map("course_code")
  slots      Slot[]
  classes    Class[]
  createdAt  DateTime @default(now())
}

model Class {
  id        Int @id @default(autoincrement())
  facultyId Int @map("facultyid")
  venueId   Int @map("roomid")
  courseId  Int

  faculty  FacultyProfile   @relation(fields: [facultyId], references: [userId])
  venue    Venue            @relation(fields: [venueId], references: [id])
  course   Course           @relation(fields: [courseId], references: [id])
  students StudentProfile[]

  createdAt DateTime    @default(now())
  status    ClassStatus @default(ONGOING)

  attendanceSessions AttendanceSession[]
}

enum ClassStatus {
  ONGOING
  COMPLETED
}

enum AttendanceSessionStatus {
  OPEN
  CLOSED
  AUTO_CLOSED
}

model AttendanceSession {
  id        Int                     @id @default(autoincrement())
  classId   Int
  date      DateTime
  startTime DateTime
  endTime   DateTime
  status    AttendanceSessionStatus @default(OPEN)

  class   Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  records AttendanceRecord[]

  createdAt DateTime @default(now())

  @@index([classId])
}

model AttendanceRecord {
  id        Int      @id @default(autoincrement())
  sessionId Int
  userId    Int
  timestamp DateTime @default(now())
  readerId  Int?

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reader  RFIDReader?       @relation(fields: [readerId], references: [id], onDelete: SetNull)

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([userId])
}
